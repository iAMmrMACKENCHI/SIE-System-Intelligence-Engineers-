---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="About SIE — Systems Intelligence Engineers"
  description="SIE exists to solve the AI implementation gap. We operate at the intersection of operational systems engineering, workflow intelligence, and AI implementation."
  canonical="https://sieconsultant.com/about"
>
  <Nav activePage="about" />
  <main style="padding-top:64px">

    <!-- Page header -->
    <section class="page-header">
      <div class="container">
        <p class="eyebrow">About</p>
        <h1 class="page-h1">The company behind the work</h1>
        <p class="page-lead">SIE is not an AI company. We are systems engineers who understand operations — and use AI as a precise instrument to improve them.</p>
      </div>
    </section>

    <!-- Mission -->
    <section class="section-pad">
      <div class="container narrow">
        <p class="eyebrow" style="margin-bottom:1rem">Mission</p>
        <blockquote class="mission-quote">
          "To engineer intelligence into operational systems."
        </blockquote>
        <p class="body-text">
          Most organizations understand that AI is important. What they don't understand is that AI alone is not intelligence for a business. True operational intelligence emerges when AI is deeply integrated into organizational systems, workflows, processes, data flows, and decision-making structures.
        </p>
        <p class="body-text">
          SIE exists to close this implementation gap. We enter organizations, study how work actually happens, identify where the friction is, and design systems that eliminate it — with or without AI, depending on what the problem actually needs.
        </p>
      </div>
    </section>

    <!-- What SIE is NOT -->
    <section class="section-pad bg-surface">
      <div class="container">
        <p class="eyebrow" style="margin-bottom:1.5rem">What SIE is not</p>
        <div class="not-grid">
          {[
            { label: 'Not an AI agency', note: 'We don\'t sell AI subscriptions, chatbot wrappers, or prompt engineering.' },
            { label: 'Not a digital agency', note: 'We don\'t build websites, apps, or dashboards as an end product.' },
            { label: 'Not automation freelancers', note: 'We don\'t connect APIs for a flat fee and call it transformation.' },
            { label: 'Not a SaaS company', note: 'We don\'t pitch a platform. We solve operational problems.' },
          ].map(n => (
            <div class="not-card">
              <span class="not-x">✕</span>
              <div>
                <strong class="not-label">{n.label}</strong>
                <p class="not-note">{n.note}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- What SIE IS -->
    <section class="section-pad">
      <div class="container">
        <p class="eyebrow" style="margin-bottom:1.5rem">What SIE is</p>
        <div class="is-grid">
          {[
            { label: 'Operational Intelligence Architects', note: 'We study, map, and redesign the systems through which organizations execute work.' },
            { label: 'Workflow Intelligence Specialists', note: 'We identify friction, bottlenecks, and information gaps across your real-world processes.' },
            { label: 'AI Implementation Engineers', note: 'We implement AI where it creates measurable ROI — embedded into the right parts of the right workflows.' },
            { label: 'Systems Thinkers', note: 'We understand that every process is connected. We design holistically, not in isolated point solutions.' },
          ].map(n => (
            <div class="is-card">
              <span class="is-check">✓</span>
              <div>
                <strong class="is-label">{n.label}</strong>
                <p class="is-note">{n.note}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Roadmap -->
    <section class="section-pad bg-surface">
      <div class="container">
        <p class="eyebrow" style="margin-bottom:1.5rem">Company roadmap</p>
        <h2 class="section-h2">How SIE evolves</h2>
        <div class="roadmap">
          {[
            { phase: 'Phase 1', label: 'AI Implementation Consultancy', status: 'Now', desc: 'Workflow audits, friction analysis, AI implementation, operational transformation.' },
            { phase: 'Phase 2', label: 'Industry Workflow Frameworks', status: 'Next', desc: 'Repeatable, industry-specific frameworks for telecom, EPC, manufacturing, and logistics.' },
            { phase: 'Phase 3', label: 'Internal Operational Tools', status: 'Building toward', desc: 'Proprietary tools built from patterns discovered during Phase 1 & 2 engagements.' },
            { phase: 'Phase 4', label: 'Vertical SaaS Products', status: 'Future', desc: 'Opinionated software for specific operational problems in specific industries.' },
            { phase: 'Phase 5', label: 'Enterprise Operational Intelligence Platform', status: 'Long-term', desc: 'A platform that gives complex organizations continuous operational visibility and intelligence.' },
          ].map((r) => (
            <div class={`roadmap-item ${r.status === 'Now' ? 'active' : ''}`}>
              <div class="roadmap-phase">
                <span class="roadmap-label">{r.phase}</span>
                <span class={`roadmap-status ${r.status === 'Now' ? 'status-now' : ''}`}>{r.status}</span>
              </div>
              <div class="roadmap-body">
                <h3 class="roadmap-title">{r.label}</h3>
                <p class="roadmap-desc">{r.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-pad cta-dark">
      <div class="container" style="text-align:center;max-width:580px;margin:0 auto">
        <p class="eyebrow" style="color:#6b7280;margin-bottom:1rem">Work with us</p>
        <h2 style="font-size:clamp(1.5rem,3vw,2.25rem);font-weight:800;color:#fff;margin:0 0 1rem;letter-spacing:-0.02em">Ready to talk about your operations?</h2>
        <p style="color:#9ca3af;font-size:0.95rem;line-height:1.65;margin:0 0 2rem">Book a 30-minute discovery call. We'll ask the right questions and tell you honestly if we can help.</p>
        <a href="../book" class="btn-primary" style="font-size:0.95rem">Book Discovery Call</a>
      </div>
    </section>

  </main>
  <Footer />
</Base>

<style>
  .container { max-width: 1100px; margin: 0 auto; }
  .narrow { max-width: 680px; }

  .page-header {
    padding: 5rem 1.5rem 4rem;
    background: #fafafa;
    border-bottom: 1px solid #e5e7eb;
  }

  .page-h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: #1a1a1a;
    margin: 0.5rem 0 1rem;
    line-height: 1.15;
  }

  .page-lead {
    font-size: 1.05rem;
    color: #4b5563;
    max-width: 580px;
    line-height: 1.65;
    margin: 0;
  }

  .mission-quote {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 700;
    font-style: italic;
    color: #1a1a1a;
    border-left: 3px solid #E9A800;
    padding-left: 1.25rem;
    margin: 0 0 2rem;
    line-height: 1.3;
  }

  .body-text {
    font-size: 1rem;
    color: #4b5563;
    line-height: 1.75;
    margin: 0 0 1.25rem;
  }

  .section-h2 {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #1a1a1a;
    margin: 0 0 2rem;
  }

  .bg-surface { background: #fafafa; }

  .not-grid, .is-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .not-card, .is-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1.25rem 1.5rem;
    border: 1px solid #e5e7eb;
    background: #fff;
  }

  .not-x { color: #d1d5db; font-size: 1rem; font-weight: 700; flex-shrink: 0; margin-top: 2px; }
  .is-check { color: #16A34A; font-size: 1rem; font-weight: 700; flex-shrink: 0; margin-top: 2px; }

  .not-label, .is-label {
    display: block;
    font-size: 0.9rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 0.25rem;
  }

  .not-note, .is-note {
    font-size: 0.85rem;
    color: #6b7280;
    margin: 0;
    line-height: 1.55;
  }

  /* Roadmap */
  .roadmap {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid #e5e7eb;
    overflow: hidden;
  }

  .roadmap-item {
    display: flex;
    gap: 0;
    border-bottom: 1px solid #e5e7eb;
    background: #fff;
    transition: background 0.15s;
  }

  .roadmap-item:last-child { border-bottom: none; }
  .roadmap-item.active { background: #fff9e6; }

  .roadmap-phase {
    width: 160px;
    flex-shrink: 0;
    padding: 1.25rem 1.5rem;
    border-right: 1px solid #e5e7eb;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    justify-content: center;
  }

  .roadmap-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6b7280;
  }

  .roadmap-status {
    font-size: 0.75rem;
    color: #9ca3af;
  }

  .status-now {
    color: #16A34A;
    font-weight: 600;
  }

  .roadmap-body {
    padding: 1.25rem 1.5rem;
  }

  .roadmap-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.375rem;
  }

  .roadmap-desc {
    font-size: 0.85rem;
    color: #6b7280;
    margin: 0;
    line-height: 1.55;
  }

  .cta-dark {
    background: #1a1a1a;
    padding: 5rem 1.5rem;
  }

  @media (max-width: 768px) {
    .not-grid, .is-grid { grid-template-columns: 1fr; }
    .roadmap-phase { width: 120px; }
    .page-header { padding: 4rem 1.25rem 3rem; }
  }
</style>