---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="SIE — Operational Intelligence for Complex Organizations"
  description="SIE engineers intelligence into operational systems. We map workflows, identify bottlenecks, and implement AI-assisted operational systems."
  canonical="https://sieconsultant.com"
>
  <Nav activePage="home" />
  <main>
    <Hero />

    <!-- ── The Problem ── -->
    <section class="section-pad problem-section">
      <div class="container">
        <p class="eyebrow" style="margin-bottom:1.25rem">The implementation gap</p>
        <div class="problem-grid">
          <div class="problem-statement">
            <h2>Most organizations are failing to extract real value from AI.</h2>
            <p>Not because of the technology — but because the operational systems it needs to run on are fragmented, undocumented, and invisible.</p>
          </div>
          <div class="problem-points">
            {[
              { stat: '$12,500', label: 'lost per employee per year to fragmented information and workflow friction' },
              { stat: '73%', label: 'of AI initiatives fail at the implementation phase — not the technology phase' },
              { stat: '6–18 mo', label: 'average time wasted before organizations realize their AI adoption is broken' },
            ].map(p => (
              <div class="stat-card">
                <span class="stat-number">{p.stat}</span>
                <p class="stat-label">{p.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── What SIE Does ── -->
    <section class="section-pad services-section">
      <div class="container">
        <p class="eyebrow" style="margin-bottom:1.25rem">What we do</p>
        <h2 class="section-h2">Engineering intelligence into operations</h2>
        <p class="section-sub">We don't sell AI tools. We study your actual operations, identify where intelligence can be embedded, and implement systems that improve how work gets done.</p>

        <div class="services-grid">
          {[
            {
              icon: '⬡',
              color: '#2563EB',
              title: 'Workflow Intelligence Audit',
              desc: 'We map how work actually happens — not how the org chart says it should. We identify bottlenecks, redundancies, and hidden friction across your operations.',
              tag: 'Phase 1',
            },
            {
              icon: '⬡',
              color: '#E9A800',
              title: 'AI Implementation Architecture',
              desc: 'We design and implement AI-assisted systems that fit your actual workflows — approval chains, reporting, document intelligence, field coordination.',
              tag: 'Phase 2',
            },
            {
              icon: '⬡',
              color: '#16A34A',
              title: 'Operational Transformation Roadmap',
              desc: 'A prioritized, measurable plan for evolving your operations — from fragmented manual processes to intelligent, scalable execution systems.',
              tag: 'Phase 3',
            },
          ].map(s => (
            <div class="service-card">
              <div class="service-tag" style={`color:${s.color}`}>{s.tag}</div>
              <h3 class="service-title">{s.title}</h3>
              <p class="service-desc">{s.desc}</p>
              <a href="../services" class="service-link">
                Learn more <span aria-hidden="true">→</span>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Who we work with ── -->
    <section class="section-pad industries-section">
      <div class="container">
        <p class="eyebrow" style="margin-bottom:2rem">Industries we serve</p>
        <div class="industry-tags">
          {['Telecom Infrastructure','Renewable Energy EPC','Construction & Engineering','Manufacturing','Logistics & Supply Chain','Utilities','Healthcare Operations','Engineering Services'].map(i => (
            <span class="industry-tag">{i}</span>
          ))}
        </div>
        <p class="industry-note">We work with execution-heavy firms (50–500 people) where operational complexity creates measurable inefficiency — and where the right systems create measurable ROI.</p>
      </div>
    </section>

    <!-- ── SIE vs AI Agencies ── -->
    <section class="section-pad comparison-section">
      <div class="container">
        <p class="eyebrow" style="margin-bottom:1.25rem">Why SIE is different</p>
        <h2 class="section-h2">AI agencies understand AI.<br/>SIE understands operations.</h2>
        <div class="comparison-table">
          <div class="comp-col comp-col--other">
            <div class="comp-header">
              <span class="comp-label">Typical AI Agency</span>
            </div>
            {[
              'Sells AI tools and subscriptions',
              'Applies AI to surface-level tasks',
              'Ignores underlying workflow structure',
              'No operational context or expertise',
              'ROI is unclear and unmeasurable',
              'Implementation is generic',
            ].map(item => (
              <div class="comp-row">
                <span class="comp-x">✕</span>
                <span>{item}</span>
              </div>
            ))}
          </div>
          <div class="comp-col comp-col--sie">
            <div class="comp-header">
              <span class="comp-label">SIE</span>
            </div>
            {[
              'Engineers intelligence into operational systems',
              'Studies actual workflows before recommending anything',
              'Redesigns processes, then applies AI where it creates ROI',
              'Deep expertise in industrial and engineering operations',
              'Every engagement has defined, measurable outcomes',
              'Implementation is specific to your workflows',
            ].map(item => (
              <div class="comp-row">
                <span class="comp-check">✓</span>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="section-pad cta-section">
      <div class="container cta-inner">
        <p class="eyebrow" style="margin-bottom:1rem;color:#9ca3af">Start here</p>
        <h2 class="cta-h2">Book a Discovery Call</h2>
        <p class="cta-sub">A 30-minute session to understand your operational context and identify whether SIE can create measurable impact for your organization.</p>
        <a href="../book" class="btn-primary" style="font-size:1rem;padding:0.875rem 2rem;">Book Discovery Session</a>
        <p class="cta-note">No sales pitch. No demo. Just an honest operational conversation.</p>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-h2 {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    color: #1a1a1a;
    line-height: 1.2;
  }

  .section-sub {
    font-size: 1.05rem;
    color: #4b5563;
    max-width: 560px;
    line-height: 1.65;
    margin: 0 0 3rem;
  }

  /* Problem */
  .problem-section { background: #fff; }

  .problem-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .problem-statement h2 {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    color: #1a1a1a;
  }

  .problem-statement p {
    color: #4b5563;
    font-size: 1rem;
    line-height: 1.7;
    margin: 0;
  }

  .problem-points { display: flex; flex-direction: column; gap: 1.5rem; }

  .stat-card {
    padding: 1.25rem 1.5rem;
    border: 1px solid #e5e7eb;
    background: #fafafa;
  }

  .stat-number {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    color: #1a1a1a;
    letter-spacing: -0.03em;
    font-family: 'Inter', sans-serif;
  }

  .stat-label {
    font-size: 0.85rem;
    color: #6b7280;
    margin: 0.25rem 0 0;
    line-height: 1.5;
  }

  /* Services */
  .services-section { background: #fafafa; }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .service-card:hover {
    border-color: #d1d5db;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
  }

  .service-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .service-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.75rem;
    line-height: 1.3;
  }

  .service-desc {
    font-size: 0.9rem;
    color: #6b7280;
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .service-link {
    display: inline-block;
    margin-top: 1.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: #2563EB;
    text-decoration: none;
    transition: gap 0.15s;
  }

  .service-link:hover { text-decoration: underline; }

  /* Industries */
  .industries-section { background: #fff; }

  .industry-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    margin-bottom: 2rem;
  }

  .industry-tag {
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.4rem 0.875rem;
    border: 1px solid #d1d5db;
    color: #374151;
    background: #f9fafb;
    letter-spacing: 0.01em;
  }

  .industry-note {
    font-size: 0.95rem;
    color: #6b7280;
    max-width: 600px;
    line-height: 1.65;
    margin: 0;
  }

  /* Comparison */
  .comparison-section { background: #fafafa; }

  .comparison-table {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .comp-col {
    border: 1px solid #e5e7eb;
    overflow: hidden;
  }

  .comp-col--sie { border-color: #1a1a1a; }

  .comp-header {
    padding: 1rem 1.5rem;
    background: #f9fafb;
    border-bottom: 1px solid #e5e7eb;
  }

  .comp-col--sie .comp-header {
    background: #1a1a1a;
    border-color: #1a1a1a;
  }

  .comp-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    color: #6b7280;
  }

  .comp-col--sie .comp-label { color: #9ca3af; }

  .comp-row {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.875rem 1.5rem;
    border-bottom: 1px solid #f3f4f6;
    font-size: 0.875rem;
    color: #4b5563;
    background: #fff;
  }

  .comp-col--sie .comp-row { background: #fff; color: #1a1a1a; }

  .comp-x { color: #d1d5db; font-weight: 700; flex-shrink: 0; }
  .comp-check { color: #16A34A; font-weight: 700; flex-shrink: 0; }

  /* CTA */
  .cta-section { background: #1a1a1a; }

  .cta-inner {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .cta-h2 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.025em;
    margin: 0 0 1rem;
  }

  .cta-sub {
    font-size: 1rem;
    color: #9ca3af;
    line-height: 1.65;
    margin: 0 0 2rem;
  }

  .cta-note {
    font-size: 0.8rem;
    color: #4b5563;
    margin: 1.25rem 0 0;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.03em;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .services-grid { grid-template-columns: 1fr; }
    .comparison-table { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .problem-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>