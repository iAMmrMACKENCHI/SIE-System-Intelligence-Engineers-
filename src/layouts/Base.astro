---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}
const { title = 'SIE', description = 'SIE', canonical = 'https://sieconsultant.com' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; }
      body { font-family: 'Inter', sans-serif; color: #1a1a1a; background: #fff; -webkit-font-smoothing: antialiased; line-height: 1.5; }
      .eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600; color: #9ca3af; }
      .section-pad { padding: 5rem 1.5rem; }
      .btn-primary { display: inline-block; background: #E9A800; color: #1a1a1a; font-weight: 700; font-size: 0.875rem; padding: 0.75rem 1.75rem; text-decoration: none; letter-spacing: 0.02em; transition: background 0.15s; border: none; cursor: pointer; }
      .btn-primary:hover { background: #d49700; }
      .btn-outline { display: inline-block; border: 1px solid #1a1a1a; color: #1a1a1a; font-weight: 600; font-size: 0.875rem; padding: 0.75rem 1.75rem; text-decoration: none; letter-spacing: 0.02em; transition: background 0.15s, color 0.15s; background: transparent; cursor: pointer; }
      .btn-outline:hover { background: #1a1a1a; color: #fff; }
      a { color: #2563EB; text-decoration: none; }
      a:hover { text-decoration: underline; }
    </style>
  </body>
</html>
