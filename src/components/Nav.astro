---
interface Props {
  activePage?: string;
}
const { activePage = '' } = Astro.props;
---

<nav class="navbar">
  <div class="nav-container">
    <a href="../" class="nav-logo">SIE</a>
    <ul class="nav-menu">
      <li><a href="../" class={activePage === 'home' ? 'active' : ''}>Home</a></li>
      <li><a href="../about" class={activePage === 'about' ? 'active' : ''}>About</a></li>
      <li><a href="../services" class={activePage === 'services' ? 'active' : ''}>Services</a></li>
      <li><a href="../careers" class={activePage === 'careers' ? 'active' : ''}>Careers</a></li>
      <li><a href="../book" class="nav-cta">Book Call</a></li>
    </ul>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    width: 100%;
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
    z-index: 100;
  }
  .nav-container { max-width: 1100px; margin: 0 auto; padding: 1rem 1.5rem; display: flex; justify-content: space-between; align-items: center; }
  .nav-logo { font-weight: 800; font-size: 1.25rem; color: #1a1a1a; text-decoration: none; }
  .nav-menu { display: flex; list-style: none; gap: 2rem; margin: 0; padding: 0; }
  .nav-menu a { text-decoration: none; color: #4b5563; font-size: 0.9rem; transition: color 0.2s; }
  .nav-menu a.active, .nav-menu a:hover { color: #E9A800; }
  .nav-cta { background: #E9A800 !important; color: #1a1a1a !important; padding: 0.5rem 1rem; border-radius: 4px; }
</style>
